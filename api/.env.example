# Copy this file to .env and fill in your values.
# Do not commit .env to git.

# Port for the server (default 3000)
PORT=3000

# Email address to receive RSVP notifications
TO_EMAIL=your-email@example.com

# SMTP settings for sending email (Nodemailer).
# Example: Gmail with App Password
# - Enable 2FA on your Google account
# - Create an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Alternative: SendGrid (use SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASS=your-sendgrid-api-key)
# Alternative: Mailgun, Outlook, etc. – use their SMTP host/port
